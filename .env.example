# このファイルをコピーして「.env」を作り、実際の値を入れてください。
#   cp .env.example .env
# .env は .gitignore で除外されているので Git には上がりません。
# 各IDが何を指すかは docs/IDS.md を参照。
#
# 【注意】コメントは「値の行」と別の行に書くこと。
#  systemd は KEY=値 の行末コメントを値の一部として取り込んでしまうため、
#  例: CH_MAIN=123  # 本スレ  ← NG（値が "123  # 本スレ" になる）

# === 認証 ===
# Discord Botのトークン（必須）
DISCORD_BOT_TOKEN=
# LINE連携用 Google Apps Script のURL（使わないなら空）
GAS_URL=

# === cron用エンドポイントの合言葉 ===
# Ubuntuのcronから /cron/wakeup を叩く時の認証キー（空だとcron機能は無効）
CRON_KEY=

# === Botのステータス表示 ===
# 「○○をプレイ中」などの表示文言（空ならデフォルト: レジェンドオブアストルム）
BOT_ACTIVITY=
# 種別: PLAYING / STREAMING / LISTENING / WATCHING / COMPETING（空なら PLAYING）
BOT_ACTIVITY_TYPE=

# === テキスト/ボイスチャンネル ===
# 本スレ
CH_MAIN=
# ボット通知
CH_INFO=
# devojapan
CH_DEVOJAPAN=
# インフォメーション(!更新)
CH_INFORMATION=
# インフォメーション確認用(!更新)
CH_INFORMATION_CHECK=
# 湯の倉庫
CH_ONSEN=
# 総合音声通話(ボイス)
VC_MAIN=

# --- 食べログ 地方別チャンネル ---
# 関西
CH_TABELOG_KANSAI=
# 関東
CH_TABELOG_KANTO=
# 東北・北海道
CH_TABELOG_TOHOKU=
# 北陸・東海
CH_TABELOG_HOKURIKU=
# 四国・中国
CH_TABELOG_CHUSHIKOKU=
# 九州・沖縄
CH_TABELOG_KYUSHU=

# === ユーザー ===
# ゲーム話題のDM通知先
USER_NOTIFY=

# === ロール ===
# 通話開演アナウンスのメンション先
ROLE_VC_ANNOUNCE=

# === カスタム絵文字（IDのみ） ===
# おいっす（食べログ/温泉まとめ用）
EMOJI_OISSU=
# おかえりリアクション
EMOJI_OKAERI=
# 帰宅絵文字（検知用）
EMOJI_KITAKU=
# リツイートマーク
EMOJI_RETWEET=

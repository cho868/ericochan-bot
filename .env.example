# このファイルをコピーして「.env」を作り、実際の値を入れてください。
#   cp .env.example .env
# .env は .gitignore で除外されているので Git には上がりません。
# 各IDが何を指すかは docs/IDS.md を参照。

# === 認証 ===
DISCORD_BOT_TOKEN=        # Discord Botのトークン（必須）
GAS_URL=                  # LINE連携用 Google Apps Script のURL（使わないなら空）

# === cron用エンドポイントの合言葉 ===
# Ubuntuのcronから /cron/wakeup を叩く時の認証キー（空だとcron機能は無効）
CRON_KEY=

# === テキスト/ボイスチャンネル ===
CH_MAIN=                  # 本スレ
CH_INFO=                  # ボット通知
CH_DEVOJAPAN=             # devojapan
CH_INFORMATION=           # インフォメーション(!更新)
CH_INFORMATION_CHECK=     # インフォメーション確認用(!更新)
CH_ONSEN=                 # 湯の倉庫
VC_MAIN=                  # 総合音声通話(ボイス)

# 食べログ 地方別チャンネル
CH_TABELOG_KANSAI=        # 関西
CH_TABELOG_KANTO=         # 関東
CH_TABELOG_TOHOKU=        # 東北・北海道
CH_TABELOG_HOKURIKU=      # 北陸・東海
CH_TABELOG_CHUSHIKOKU=    # 四国・中国
CH_TABELOG_KYUSHU=        # 九州・沖縄

# === ユーザー ===
USER_NOTIFY=              # ゲーム話題のDM通知先

# === ロール ===
ROLE_VC_ANNOUNCE=         # 通話開演アナウンスのメンション先

# === カスタム絵文字（IDのみ） ===
EMOJI_OISSU=              # おいっす（食べログ/温泉まとめ用）
EMOJI_OKAERI=             # おかえりリアクション
EMOJI_KITAKU=             # 帰宅絵文字（検知用）
EMOJI_RETWEET=            # リツイートマーク
